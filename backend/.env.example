# ─────────────────────────────────────────────────────────────
#  .env.example — copy to .env and fill in your values
#  ⚠️  Never commit .env to git
# ─────────────────────────────────────────────────────────────

# App
DEBUG=false
ENVIRONMENT=development     # Change to "production" when deploying

# Security — generate with: openssl rand -hex 32
SECRET_KEY=your-secret-key-here
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# MongoDB
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=yt_course_assistant

# Redis (Celery broker + result backend)
REDIS_URL=redis://localhost:6379/0

# ChromaDB
CHROMA_PERSIST_DIR=./chroma_store
CHROMA_COLLECTION_NAME=course_chunks

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_LLM_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# RAG
RAG_TOP_K=6

# CORS (comma-separated for multiple origins)
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Email (optional for now — needed for email verification)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASSWORD=your-app-password
EMAILS_FROM=no-reply@ytcourseassistant.com
